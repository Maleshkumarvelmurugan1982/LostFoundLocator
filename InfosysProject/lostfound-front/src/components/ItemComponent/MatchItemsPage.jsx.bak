import React, { useEffect, useState } from "react";
import axios from "axios";
import "./match.css";

const BASE = "http://localhost:9595/lostfound";

function MatchItemsPage() {
  const [matches, setMatches] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);

  useEffect(() => {
    fetch(`${BASE}/match`)
      .then(res => {
        if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
        return res.json();
      })
      .then(data => {
        console.log("Matches loaded:", data);
        setMatches(Array.isArray(data) ? data : [data]);
        setLoading(false);
      })
      .catch(err => {
        console.error("Fetch error:", err);
        setError(err.message);
        setLoading(false);
      });
  }, []);

  const getInitial = (val) =>
    val ? val.charAt(0).toUpperCase() : "?";

  const getImage = (img) => {
    if (!img) return "https://via.placeholder.com/60";
    return `${BASE}/uploads/${img}`;
  };

  return (
    <div className="match-page">
      {/* BACKGROUND */}
      <div className="match-bg"></div>
      <div className="match-overlay"></div>

      {/* HEADER */}
      <div className="match-header">
        <div>
          <h1 className="match-title">
            Matched <em>Items</em>
          </h1>
          <p className="match-subtitle">
            View all successfully matched lost &amp; found items
          </p>
        </div>
        <button
          className="match-back-btn"
          onClick={() => window.history.back()}
        >
          ← Back
        </button>
      </div>

      {/* CONTENT */}
      <div className="match-container">

        {/* ERROR */}
        {error && (
          <div style={{
            background: "rgba(220,50,50,0.15)",
            border: "1px solid rgba(220,50,50,0.4)",
            borderRadius: "10px",
            padding: "16px 20px",
            marginBottom: "20px",
            color: "#ff6b6b",
            fontSize: "15px"
          }}>
            ⚠ Failed to load matches: {error}
          </div>
        )}

        {/* MATCH COUNT */}
        {!loading && !error && (
          <p style={{ marginBottom: "20px", fontSize: "16px", color: "rgba(255,255,255,0.6)" }}>
            {matches.length} {matches.length === 1 ? "match" : "matches"} found
          </p>
        )}

        {/* TABLE CARD */}
        <div className="match-table-wrapper">

          {/* LOADING */}
          {loading && (
            <div className="match-empty">
              Loading matches...
            </div>
          )}

          {/* EMPTY */}
          {!loading && !error && matches.length === 0 && (
            <div className="match-empty">
              No matches found
            </div>
          )}

          {/* TABLE */}
          {!loading && matches.length > 0 && (
            <table className="match-table">
              <thead>
                <tr>
                  <th>Lost ID</th>
                  <th>Found ID</th>
                  <th>Image</th>
                  <th>Item</th>
                  <th>Category</th>
                  <th>Lost User</th>
                  <th>Found User</th>
                </tr>
              </thead>
              <tbody>
                {matches.map((match, index) => (
                  <tr key={index}>
                    <td>{match.lostItemId}</td>
                    <td>{match.foundItemId}</td>
                    <td>
                      <img
                        className="match-img"
                        src={getImage(match.image)}
                        alt="item"
                        onError={e => { e.target.src = "https://via.placeholder.com/60"; }}
                      />
                    </td>
                    <td>{match.itemName}</td>
                    <td>{match.category}</td>
                    <td>
                      <div className="match-user">
                        <div className="match-user-circle">
                          {getInitial(match.lostUsername)}
                        </div>
                        {match.lostUsername}
                      </div>
                    </td>
                    <td>
                      <div className="match-user">
                        <div className="match-user-circle">
                          {getInitial(match.foundUsername)}
                        </div>
                        {match.foundUsername}
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>
      </div>
    </div>
  );
}

export default MatchItemsPage;
